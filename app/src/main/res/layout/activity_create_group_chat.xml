<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Назад"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Новая группа"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/groupAvatarPreview"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_logo_gradient"
            android:scaleType="centerCrop"
            android:contentDescription="Аватар группы"
            android:clickable="true"
            android:focusable="true"/>

        <EditText
            android:id="@+id/groupNameInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:hint="Название группы"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:maxLines="1"
            android:inputType="text"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/phoneSearchInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="+79991234567"
            android:inputType="phone"
            android:background="@drawable/bg_search_field"
            android:padding="12dp"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/addByPhoneButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Найти"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"/>
    </LinearLayout>


    <TextView
        android:id="@+id/emptyContactsHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Список контактов пуст. Добавьте участников по номеру телефона."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/contactsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <Button
        android:id="@+id/createButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Выберите минимум 2 контакта"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/surface"
        android:enabled="false"
        android:background="@drawable/bg_create_chat_button"/>

</LinearLayout>