<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="@color/background"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Назад"
            app:tint="#1F2937"/>

        <ImageView
            android:id="@+id/partnerAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Аватар собеседника"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_logo_gradient"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/chatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+79108791279"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1F2937"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:id="@+id/statusIcon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_status_offline"
                    android:contentDescription="Статус"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Оффлайн"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:visibility="visible"/>
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/menuIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more"
            android:contentDescription="Меню"
            app:tint="#1F2937"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/topProgressBar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:padding="12dp"
        android:indeterminate="true"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/topProgressBar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"/>

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/inputContainer">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_hand"
            android:contentDescription="Нет сообщений"
            android:scaleType="centerInside"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Это начало переписки.\nНапишите первое сообщение"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:textAlignment="center"
            android:layout_marginBottom="32dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/noConnectionState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="32dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toTopOf="@id/inputContainer">

        <TextView
            android:id="@+id/noConnectionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нет соединения"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#EF4444"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/retryButton"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_create_chat_button"
            android:text="Повторить"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@color/background"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/attachButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_attach"
            android:contentDescription="Прикрепить"
            android:layout_marginEnd="6dp"
            android:scaleType="centerInside"
            android:padding="3dp"/>

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_search_field"
            android:hint="Введите сообщение"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textSize="14sp"
            android:textColor="#1F2937"
            android:textColorHint="#9CA3AF"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:imeOptions="actionSend"/>

        <ImageView
            android:id="@+id/sendButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_send"
            android:contentDescription="Отправить"
            android:layout_marginStart="6dp"
            android:scaleType="centerInside"
            android:padding="3dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>